# Auto detect text files and normalize line endings to LF
* text=auto

# .NET specific
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.xaml text eol=lf
*.config text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.dll binary
*.exe binary
*.pdb binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Office documents
*.docx binary
*.xlsx binary
*.pptx binary
